# ============================================================
# Data — tái tạo bằng scripts/*_phase1.py. Bỏ NỘI DUNG, giữ skeleton.
# (ignore cả dir thì !.gitkeep vô hiệu → phải dùng dir/* rồi chừa .gitkeep)
# ============================================================
data/raw/*
!data/raw/.gitkeep
data/interim/*
!data/interim/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/cache/

# ============================================================
# Models & training artifacts — tái tạo bằng ĐV5 (freeze refit-on-all)
# ============================================================
*.pkl
*.joblib
*.pt
*.pth
*.h5
*.onnx
checkpoints/
runs/
models/

# ============================================================
# Database (Phase 2+)
# ============================================================
*.db
*.sqlite
*.sqlite3
*.sqlite3-journal

# ============================================================
# Web outputs
#   - app_data.json: tái tạo bằng web_build/web_app  → ignore
#   - tcb_dashboard.html: deliverable TỰ CHỨA, mở mọi máy → GIỮ (commit)
#     (bỏ comment dòng dưới nếu muốn coi nó là build-output thay vì deliverable)
# ============================================================
web/app_data.json
# web/tcb_dashboard.html

# ============================================================
# Debug dumps & diagnostic outputs
# ============================================================
diagnose_output.txt
explorer_output.txt
data/raw/_debug/

# ============================================================
# GIỮ trong repo (không ignore): toàn bộ src/, scripts/, config/*.json,
#   data.md, requirements.txt, notebook/, reports/ (results.json + figures + eda),
#   deploy/manifest.json, web/index.html, web/tcb_dashboard.html
# ============================================================