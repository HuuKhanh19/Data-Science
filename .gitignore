# ============================================================
# Data files (regeneratable từ scripts/fetch_phase1.py)
# ============================================================
# Raw data — ignore parquet & json log, keep folder structure
data/raw/*.parquet
data/raw/*.csv
data/raw/_fetch_log.json
data/raw/*.log

# Processed features & intermediate
data/processed/
data/cache/
data/interim/

# Keep folder skeletons (commit .gitkeep nếu muốn lưu structure)
!data/raw/.gitkeep
!data/processed/.gitkeep

